-- Log Oynasi
local LogFrame = Instance.new("ScrollingFrame", Main)
LogFrame.Size = UDim2.new(0, 200, 1, -60)
LogFrame.Position = UDim2.new(1, -210, 0, 55)
LogFrame.BackgroundColor3 = Color3.fromRGB(5, 5, 10)
LogFrame.CanvasSize = UDim2.new(0, 0, 20, 0)
Instance.new("UIListLayout", LogFrame)

local function PushLog(txt)
    local l = Instance.new("TextLabel", LogFrame)
    l.Size = UDim2.new(1, 0, 0, 25)
    l.Text = "> " .. txt
    l.TextColor3 = Color3.fromRGB(0, 200, 255)
    l.BackgroundTransparency = 1
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.TextWrapped = true
    LogFrame.CanvasPosition = Vector2.new(0, 99999)
end

-- Tugmalar Paneli
local Buttons = Instance.new("ScrollingFrame", Main)
Buttons.Size = UDim2.new(0, 320, 1, -60)
Buttons.Position = UDim2.new(0, 10, 0, 55)
Buttons.BackgroundTransparency = 1
Instance.new("UIListLayout", Buttons).Padding = UDim.new(0, 5)

local function MakeBtn(name, color, func)
    local b = Instance.new("TextButton", Buttons)
    b.Size = UDim2.new(1, -10, 0, 40)
    b.Text = name
    b.BackgroundColor3 = color
    b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.GothamBold
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(func)
end

-- --- FUNKSIYALAR ---

-- 1. Predictor (Mashina nima chiqarishini aytadi)
MakeBtn("🔮 START BRAINROT PREDICTOR", Color3.fromRGB(120, 0, 255), function()
    PushLog("Skanerlanmoqda...")
    if NetPath then
        NetPath.SpawnMachines.SpawnMachineCombineResult.OnClientEvent:Connect(function(res)
            PushLog("NATIJA: Keyingi chiqadigan narsa: " .. tostring(res))
            -- Ekran o'rtasida katta ogohlantirish
            local hint = Instance.new("Hint", workspace)
            hint.Text = "DIQQAT: KEYINGI BRAINROT -> " .. tostring(res)
            task.wait(4)
            hint:Destroy()
        end)
        PushLog("Predictor tayyor! Mashinani ishlating.")
    else
        PushLog("Xato: Networking topilmadi!")
    end
end)

-- 2. Event Spam (Serverni "Brainrot" qilish)
MakeBtn("⚡ TRIGGER ALL EVENTS (GALAXY/MAGMA)", Color3.fromRGB(0, 150, 0), function()
    if NetPath then
        pcall(function()
            NetPath.Events.GalaxySpawnComet:FireServer()
            NetPath.Events.MagmaSpawnFireball:FireServer()
            NetPath.Events.AcidRainSpawnCloud:FireServer()
        end)
        PushLog("Barcha eventlar serverga yuborildi!")
    end
end)

-- 3. Player Ban/Kick GUI (Sening logingdagi AFKLuckSync orqali)
MakeBtn("🚫 BAN/KICK PLAYER (SELECT)", Color3.fromRGB(180, 0, 0), function()
    PushLog("O'yinchilar ro'yxati skan qilinmoqda...")
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LPlayer then
            pcall(function()
                NetPath.Misc.AFKLuckSync:FireServer(p, "kick")
            end)
            PushLog("Targeted: " .. p.Name)
        end
    end
end)

-- 4. Luck 100x (Visual + Sync Attempt)
MakeBtn("🍀 ACTIVATE 100x LUCK", Color3.fromRGB(0, 200, 150), function()
    task.spawn(function()
        for i = 1, 50 do
            NetPath.Misc.AFKLuckSync:FireServer(true)
            task.wait(0.1)
        end
    end)
    PushLog("Luck Sync 100x yoqildi!")
end)

